{
  "info": {
    "name": "Admin Delivery Postponement API",
    "description": "Admin Panel - Delivery postponement requests: list, approve (with optional date change), reject with reason. All endpoints require Admin role and Bearer token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8050/api/v1"
    },
    {
      "key": "adminToken",
      "value": "YOUR_ADMIN_JWT_TOKEN"
    },
    {
      "key": "postponementId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Admin - List Postponements",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/postponements?status=Pending&page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "postponements"],
          "query": [
            {
              "key": "status",
              "value": "Pending",
              "description": "Filter: Pending | Approved | Rejected | Cancelled"
            },
            {
              "key": "page",
              "value": "1",
              "description": "Page number (default 1)"
            },
            {
              "key": "limit",
              "value": "10",
              "description": "Items per page (1-100, default 10)"
            }
          ]
        },
        "description": "List all delivery postponement requests. Optional query: status (Pending/Approved/Rejected/Cancelled), page, limit. Admin only."
      }
    },
    {
      "name": "Admin - Approve Postponement",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"approvedDeliveryDate\": \"2026-03-15T00:00:00.000Z\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/postponements/{{postponementId}}/approve",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "postponements", "{{postponementId}}", "approve"]
        },
        "description": "Approve a postponement request. Body optional: approvedDeliveryDate (ISO string) to set a different delivery date; omit to keep requested date. Admin only."
      }
    },
    {
      "name": "Admin - Approve Postponement (no date change)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/postponements/{{postponementId}}/approve",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "postponements", "{{postponementId}}", "approve"]
        },
        "description": "Approve without changing the requested delivery date. Send empty object {}."
      }
    },
    {
      "name": "Admin - Reject Postponement",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Delivery slot not available for the requested date.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/postponements/{{postponementId}}/reject",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "postponements", "{{postponementId}}", "reject"]
        },
        "description": "Reject a postponement request. Body required: reason (string, 1-1000 chars). Admin only."
      }
    }
  ]
}
