{
  "info": {
    "name": "Contact Us Module - Viteezy",
    "description": "APIs for Contact form (Ask us a question), Footer email signup, and Admin contact inquiries list/detail.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8050"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Public - Contact & Footer",
      "item": [
        {
          "name": "Submit Contact Form (Ask us a question)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"General inquiry\",\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"+1234567890\",\n  \"message\": \"I have a question about your products.\",\n  \"privacyAccepted\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/contact",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "contact"]
            },
            "description": "Submit contact form. Required: subject, email, message, privacyAccepted. Optional: name, phone. Sends confirmation email via SendGrid."
          }
        },
        {
          "name": "Footer Subscribe (Welcome / Promo email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/contact/footer-subscribe",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "contact", "footer-subscribe"]
            },
            "description": "Footer email signup. Stores email and sends welcome/promotional email via SendGrid (only for new signups)."
          }
        }
      ]
    },
    {
      "name": "Admin - Contact Inquiries",
      "item": [
        {
          "name": "List Contact Inquiries",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/contacts?page=1&limit=10&search=",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "contacts"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "List all contact form submissions. Paginated. Optional: search (searches subject, name, email, phone, message). Admin only."
          }
        },
        {
          "name": "Get Contact Inquiry by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/contacts/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "contacts", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "CONTACT_INQUIRY_ID"
                }
              ]
            },
            "description": "Get a single contact inquiry by ID. Admin only. Replace :id with actual MongoDB ObjectId."
          }
        }
      ]
    }
  ]
}
