{
  "info": {
    "name": "Header Banner API",
    "description": "Admin Panel - Header Banner stripe management with scheduled and direct publish banners. IMPORTANT: All startDate/endDate are in UTC. For 9:52 AM IST use 04:22:00.000Z (IST = UTC+5:30).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8050/api/v1"
    },
    {
      "key": "adminToken",
      "value": "YOUR_ADMIN_JWT_TOKEN"
    },
    {
      "key": "bannerId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Admin - Create Scheduled Banner (WEB)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Scheduled Banner for Web - Special Offer!\",\n  \"deviceType\": \"WEB\",\n  \"isScheduled\": true,\n  \"startDate\": \"2026-02-20T09:52:00.000Z\",\n  \"endDate\": \"2026-02-25T18:00:00.000Z\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/header-banners",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "header-banners"]
        },
        "description": "Create a scheduled banner for WEB. Dates are UTC. For 9:52 AM IST use startDate: 2026-02-20T04:22:00.000Z. Start/end must be future. No overlapping schedules per device type."
      }
    },
    {
      "name": "Admin - Create Scheduled Banner (MOBILE)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Scheduled Banner for Mobile App\",\n  \"deviceType\": \"MOBILE\",\n  \"isScheduled\": true,\n  \"startDate\": \"2026-02-20T09:52:00.000Z\",\n  \"endDate\": \"2026-02-25T18:00:00.000Z\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/header-banners",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "header-banners"]
        },
        "description": "Create a scheduled banner for MOBILE."
      }
    },
    {
      "name": "Admin - Create Direct Publish Banner",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Direct Publish Banner - Active Now\",\n  \"deviceType\": \"WEB\",\n  \"isActive\": true,\n  \"isScheduled\": false\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/header-banners",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "header-banners"]
        },
        "description": "Create a banner that goes live immediately (no schedule). Only one active per device type."
      }
    },
    {
      "name": "Admin - Get All Banners",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/header-banners?page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "header-banners"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "deviceType",
              "value": "WEB",
              "disabled": true
            },
            {
              "key": "isActive",
              "value": "true",
              "disabled": true
            },
            {
              "key": "search",
              "value": "",
              "disabled": true
            }
          ]
        },
        "description": "Get all header banners with pagination. Optional: deviceType (WEB/MOBILE), isActive, search."
      }
    },
    {
      "name": "Admin - Run Schedule Job (Manual Trigger)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/header-banners/run-schedule-job",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "header-banners", "run-schedule-job"]
        },
        "description": "Manually run the cron that activates/deactivates scheduled banners. Use to test without waiting for cron minute."
      }
    },
    {
      "name": "Admin - Get Banner by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/header-banners/{{bannerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "header-banners", "{{bannerId}}"]
        },
        "description": "Get a single banner by ID. Set bannerId in collection variables after creating a banner."
      }
    },
    {
      "name": "Admin - Update Banner (Schedule)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Updated Banner Text\",\n  \"isScheduled\": true,\n  \"startDate\": \"2026-02-21T09:52:00.000Z\",\n  \"endDate\": \"2026-02-26T20:00:00.000Z\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/header-banners/{{bannerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "header-banners", "{{bannerId}}"]
        },
        "description": "Update banner. Can change text, schedule, or convert to/from scheduled."
      }
    },
    {
      "name": "Admin - Update Banner (Direct Publish)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"isScheduled\": false,\n  \"isActive\": true,\n  \"startDate\": null,\n  \"endDate\": null\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/header-banners/{{bannerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "header-banners", "{{bannerId}}"]
        },
        "description": "Convert scheduled banner to direct publish and set active."
      }
    },
    {
      "name": "Admin - Toggle Banner Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/header-banners/{{bannerId}}/toggle-status",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "header-banners", "{{bannerId}}", "toggle-status"]
        },
        "description": "Toggle isActive (on/off). Only one active per device type."
      }
    },
    {
      "name": "Admin - Delete Banner",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/header-banners/{{bannerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "header-banners", "{{bannerId}}"]
        },
        "description": "Soft delete a banner."
      }
    },
    {
      "name": "Public - Get Active Banner (WEB)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/header-banner?deviceType=WEB",
          "host": ["{{baseUrl}}"],
          "path": ["header-banner"],
          "query": [
            {
              "key": "deviceType",
              "value": "WEB"
            }
          ]
        },
        "description": "Public endpoint. Get currently active banner for WEB. No auth required."
      }
    },
    {
      "name": "Public - Get Active Banner (MOBILE)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/header-banner?deviceType=MOBILE",
          "host": ["{{baseUrl}}"],
          "path": ["header-banner"],
          "query": [
            {
              "key": "deviceType",
              "value": "MOBILE"
            }
          ]
        },
        "description": "Public endpoint. Get currently active banner for MOBILE. No auth required."
      }
    }
  ]
}
