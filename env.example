# Copy to .env and fill every required value. No real credentials belong in this file.

# --- Core ---
NODE_ENV=development
PORT=8080
HOST=0.0.0.0

# --- Database ---
MONGODB_URI=mongodb://127.0.0.1:27017/viteezy
MONGODB_TEST_URI=mongodb://127.0.0.1:27017/viteezy-test

# --- JWT (no code defaults; required) ---
JWT_SECRET=replace_with_at_least_32_random_chars
JWT_REFRESH_SECRET=replace_with_at_least_32_random_chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# --- URLs ---
# In development/test, if unset, APP_BASE_URL defaults to http://127.0.0.1:$PORT
# Production: must set explicitly (validated).
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080
ADMIN_PANEL_URL=http://localhost:8081
CORS_ORIGIN=http://localhost:8080,http://localhost:3000

# --- SMTP (required by schema; use your provider) ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# --- Brevo (transactional email; API key optional if unused) ---
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@yourdomain.com
BREVO_FROM_NAME=YourAppName

# --- OTP / admin ---
OTP_EXPIRES_IN=5
ADMIN_EMAIL=ops@yourdomain.com
# Optional fallback for admin notification "from" / delivery emails when ADMIN_EMAIL is empty
SENDGRID_FROM_EMAIL=

# --- Upload & rate limit ---
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=logs/app.log

# --- DigitalOcean Spaces (optional; leave empty if not used) ---
DIGITALOCEAN_SPACES_ENDPOINT=
DIGITALOCEAN_CALLBACK_URL=
DIGITALOCEAN_SPACES_REGION=
DIGITALOCEAN_BUCKET_NAME=
DIGITALOCEAN_ACCESS_KEY=
DIGITALOCEAN_SPACES_SECRET_KEY=
DIGITALOCEAN_CLIENT_SECRET=
DO_SPACES_CDN_BASE_URL=

# --- PostNL ---
POSTNL_URL=https://api.postnl.nl/v2/address/benelux
POSTNL_API_KEY=
POSTNL_SHIPMENT_API_KEY=
POSTNL_TIMEOUT_MS=5000
POSTNL_API_URL=https://api.postnl.nl
POSTNL_CUSTOMER_NUMBER=
POSTNL_XML_FOLDER=
POSTNL_RESPONSE_XML_FOLDER=
POSTNL_STATUS_SYNC_SCHEDULE=*/30 * * * *
POSTNL_RESPONSE_JOB_SCHEDULE=*/5 * * * *
POSTNL_FULFILMENT_JOB_SCHEDULE=*/5 * * * *

# --- PostNL SFTP (optional; required only for XML/SFTP flows) ---
SFTP_REMOTE_HOST=
SFTP_USERNAME=
SFTP_PORT=22
SFTP_PRIVATEKEY_FILENAME=
# Or paste PEM (multi-line) — prefer file in production
SFTP_PRIVATE_KEY=

# --- Infobip SMS (optional: leave URL/from empty to disable SMS) ---
INFOBIP_URL=
INFOBIP_API_KEY=
SMS_FROM=

# --- Payments (optional per gateway) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MOLLIE_API_KEY=

# --- PDF service (packing slips; leave empty to skip job) ---
PDF_GENERATION_API_URL=

# --- Pharmacist CSV job ---
# If empty: uses ./data/pharmacist-csv under process.cwd()
PHARMACIST_CSV_FOLDER=
PHARMACIST_EMAIL=pharmacist@yourdomain.com
PHARMACIST_CSV_SUBJECT=Pharmacist order CSV export
PHARMACIST_JOB_SCHEDULE=*/5 * * * *

# --- Scheduled jobs (cron) ---
PACKING_SLIP_PDF_JOB_SCHEDULE=*/5 * * * *
COUPON_SCHEDULE_JOB_CRON=*/5 * * * *
HEADER_BANNER_CRON_SCHEDULE=*/5 * * * *
SUBSCRIPTION_RENEWAL_CRON_PRODUCTION=0 2 * * *
SUBSCRIPTION_RENEWAL_CRON_NON_PRODUCTION=0 * * * *

# --- Google / translation ---
GOOGLE_CLIENT_ID=
GOOGLE_TRANSLATE_API_KEY=
TRANSLATION_ENABLED=false

# --- Push (optional) ---
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# --- Proxy / Express ---
BEHIND_PROXY=false
TRUST_PROXY=

# --- Feature flags ---
AUTO_CREATE_SUBSCRIPTION_ON_PAYMENT=false
