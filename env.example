# Server Configuration
NODE_ENV=development
PORT=8080
HOST=localhost

# Database Configuration
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/your-db-name
# MONGODB_TEST_URI=mongodb+srv://user:password@cluster.mongodb.net/your-db-test

# JWT Configuration
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRE=30d

# Email Configuration (fallback if SendGrid not used)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=harsh.logicgo6@gmail.com
# SMTP_PASS=acwtvqryginfffxw
# SMTP_FROM=harsh.logicgo6@gmail.com

# Email Configuration (Brevo)
BREVO_API_KEY=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
BREVO_FROM_EMAIL=noreply@viteezy.com
BREVO_FROM_NAME=Viteezy

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:8080

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Payment Gateway Configuration
# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Mollie Configuration
MOLLIE_API_KEY=test_your_mollie_api_key_here

# PostNL Configuration (address validation in NL, BE, LU)
POSTNL_API_KEY=your_postnl_api_key_here
POSTNL_URL=https://api.postnl.nl/v2/address/benelux
POSTNL_TIMEOUT_MS=5000

# PostNL Shipment (fulfilment XML upload, barcode response, status sync)
POSTNL_API_URL=https://api.postnl.nl
POSTNL_SHIPMENT_API_KEY=your_postnl_shipment_api_key_here
POSTNL_CUSTOMER_NUMBER=10825993
# SFTP key: file path OR raw key content (required for upload/download)
# SFTP_PRIVATEKEY_FILENAME=D:/path/to/postnl-sftp-key.pem
# SFTP_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----..."
SFTP_REMOTE_HOST=sftp-gateway-transfer.a16.cldsvc.net
SFTP_USERNAME=sftpviteezya
SFTP_PORT=22

# SMS / Infobip (pickup point notifications when shipment = AT_PICKUP_POINT)
INFOBIP_API_KEY=your_infobip_api_key_here
INFOBIP_URL=https://dmdlzg.api.infobip.com
SMS_FROM=Viteezy

# PDF Generation (packing slip – Python service URL)
PDF_GENERATION_API_URL=https://staging-v2.viteezy.com/py/api/v1/generate-pdf

# Pharmacist (CSV export folder and email)
PHARMACIST_CSV_FOLDER=/data/csv
PHARMACIST_EMAIL=pharmacist@viteezy.com
PHARMACIST_CSV_SUBJECT=Pharmacist Order CSV Files

# Cron Jobs (optional – defaults are set in code; override here if needed)
# Format: minute hour day month weekday (e.g. */5 * * * * = every 5 min)
# PACKING_SLIP_PDF_JOB_SCHEDULE=*/5 * * * *
# PHARMACIST_JOB_SCHEDULE=*/5 * * * *
# POSTNL_FULFILMENT_JOB_SCHEDULE=*/5 * * * *
# POSTNL_RESPONSE_JOB_SCHEDULE=*/5 * * * *
# POSTNL_STATUS_SYNC_SCHEDULE=*/30 * * * *
# HEADER_BANNER_CRON_SCHEDULE=*/5 * * * *

# Application Base URL (for payment redirects and webhooks)
APP_BASE_URL=http://localhost:8080

# Frontend URL (for payment redirects)
FRONTEND_URL=http://localhost:8080

# Admin Panel URL (for admin password reset links, etc.)
ADMIN_PANEL_URL=http://localhost:8081

# Translation Configuration (Google Translate API)
TRANSLATION_ENABLED=true
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# Development/Testing Configuration
# Set to 'true' to auto-create subscriptions immediately on payment creation (for testing only)
# In production, subscriptions are created via webhook after payment completion
# WARNING: Only use in development/testing - not recommended for production
AUTO_CREATE_SUBSCRIPTION_ON_PAYMENT=false

# Push Notification Configuration
# OneSignal Configuration (for mobile app push notifications)
ONESIGNAL_APP_ID=your_onesignal_app_id_here
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key_here

# Firebase Configuration (for web push notifications - future scope)
# Firebase is initialized via firebaseService, no additional env vars needed here
# FIREBASE_SERVICE_ACCOUNT is handled in firebaseService.ts

# DigitalOcean Spaces Configuration
DIGITALOCEAN_SPACES_ENDPOINT=https://ams3.digitaloceanspaces.com
DIGITALOCEAN_SPACES_REGION=ams3
DIGITALOCEAN_BUCKET_NAME=your-space-name
DIGITALOCEAN_ACCESS_KEY=your-access-key
DIGITALOCEAN_SPACES_SECRET_KEY=your-secret-key
DO_SPACES_CDN_BASE_URL=https://cdn.your-domain.com
